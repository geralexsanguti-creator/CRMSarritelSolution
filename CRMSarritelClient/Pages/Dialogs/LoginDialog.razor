@inherits MudBlazor.MudDialog
@using MudBlazor
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject NavigationManager Nav

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5">Iniciar Sesión</MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@isValid">
            <MudTextField @bind-Value="usuario.Username"
                          Label="Nombre de usuario"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="El nombre es obligatorio"
                          Immediate="true" />

            <MudTextField @bind-Value="usuario.Password"
                          Label="Contraseña"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="La contraseña es obligatoria"
                          InputType="@PasswordInput"
                          Adornment="Adornment.End"
                          AdornmentIcon="@PasswordInputIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Immediate="true"
                          Class="mt-4" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Cancelar</MudButton>
        <MudButton OnClick="SubmitAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!isValid)">Iniciar sesión</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm form = default!;
    private bool isValid = false;

    private UsuarioDto usuario = new();
    private InputType PasswordInput = InputType.Password;
    private string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        if (PasswordInput == InputType.Password)
        {
            PasswordInput = InputType.Text;
            PasswordInputIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            PasswordInput = InputType.Password;
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private async Task SubmitAsync()
    {
        await form.Validate();
        if (!isValid) return;

        try
        {
            var payload = new { usuario.Username, usuario.Password };
            var response = await Http.PostAsJsonAsync("api/auth/login", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TokenResponse>()
                             ?? new TokenResponse { Token = "" };

                if (!string.IsNullOrWhiteSpace(result.Token))
                {
                    await LocalStorage.SetItemAsync("authToken", result.Token);
                    // Si tienes CustomAuthStateProvider:
                    // AuthStateProvider?.NotifyUserAuthentication(result.Token);

                    Nav.NavigateTo("/");
                    MudDialog.Close(DialogResult.Ok(true));
                    return;
                }
            }

            await DialogService.ShowMessageBox("Error de inicio de sesión",
                "Credenciales inválidas o problema en el servidor.",
                yesText: "Aceptar");
        }
        catch (Exception ex)
        {
            await DialogService.ShowMessageBox("Error inesperado", ex.Message, yesText: "Aceptar");
        }
        // No cerramos el diálogo en caso de error → el usuario puede corregir
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private class TokenResponse
    {
        public string Token { get; set; } = "";
    }

    
}